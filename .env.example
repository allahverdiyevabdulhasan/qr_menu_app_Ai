# ============================================================
# NeyMenu AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ── Django Core ──────────────────────────────────────────────
# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION

DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated origins for CSRF (must match your protocol + domain + port)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000

# Set to True in production behind HTTPS
SECURE_SSL_REDIRECT=False

# ── Database ──────────────────────────────────────────────────
# Leave DB_HOST blank to use SQLite (local dev without PostgreSQL)
DB_HOST=
DB_PORT=5432
DB_NAME=neymenu_db
DB_USER=postgres
DB_PASSWORD=postgres
# DB_ENGINE=django.db.backends.postgresql  # default when DB_HOST is set

# ── Redis / WebSockets ────────────────────────────────────────
# Leave blank to use InMemoryChannelLayer (no real-time in dev)
REDIS_URL=

# ── AI Provider ───────────────────────────────────────────────
# Leave blank → MockAIProvider (deterministic fake responses, no API needed)
# Set to a real key → OpenAI-compatible provider is activated
AI_API_KEY=

# Optional: override the AI base URL (default: https://api.openai.com/v1)
# AI_BASE_URL=https://api.openai.com/v1

# Optional: override the model (default: gpt-4o-mini)
# AI_MODEL=gpt-4o-mini

# ── CORS (production) ─────────────────────────────────────────
# Comma-separated allowed origins. Leave blank in dev to allow all (DEBUG=True).
CORS_ALLOWED_ORIGINS=
